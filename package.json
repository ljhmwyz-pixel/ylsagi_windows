{
  "name": "ylsagi-codex-monitor",
  "version": "1.0.0",
  "description": "Windows floating quota monitor for Codex API.",
  "main": "main.js",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "author": "ylsagi",
  "scripts": {
    "start": "node scripts/dev.js",
    "dev": "node scripts/dev.js",
    "verify": "node scripts/verify.js",
    "build": "vite build",
    "electron": "node scripts/start-electron.js",
    "pack": "pnpm run build && electron-builder --win portable",
    "dist": "pnpm run build && electron-builder --win nsis",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "com.ylsagi.codex.monitor",
    "productName": "Codex Monitor",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "asar": true,
    "compression": "maximum",
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "files": [
      "main.js",
      "preload.js",
      "assets/**/*",
      "src/main/**/*",
      "renderer-dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "electronDist": "node_modules/electron/dist",
    "electronDownload": {
      "cache": "node_modules/electron/dist"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        },
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vite-plugin-solid": "^2.11.0"
  },
  "dependencies": {
    "solid-js": "^1.9.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
